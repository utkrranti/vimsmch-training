generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Course {
  id                String   @id @default(cuid()) @map("_id")
  slug              String   @unique
  title             String
  shortDesc         String
  fullDesc          String
  nsqf              Int
  durationMonths    Int
  durationHours     Int
  fees              Int
  feeBreakdown      Json
  seats             Int
  eligibility       String
  ageLimit          String
  certBy            String
  assessmentScheme  String
  creditEquivalence String
  objectives        Json
  highlights        Json
  syllabus          Json
  clinicalPostings  Json
  outcomes          Json
  tags              Json
  category          String
  batchMonths       Json
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  inquiries    Inquiry[]
  enrollments  Enrollment[]
  batches      Batch[]
  galleryItems GalleryItem[]
  placements   Placement[]

  @@map("courses")
}

model Inquiry {
  id        String        @id @default(cuid()) @map("_id")
  name      String
  email     String?
  phone     String
  message   String?
  courseId  String?
  course    Course?       @relation(fields: [courseId], references: [id])
  status    String        @default("PENDING")
  ipAddress String?
  createdAt DateTime      @default(now())

  @@map("inquiries")
}

model Enrollment {
  id        String   @id @default(cuid()) @map("_id")
  name      String
  email     String
  phone     String
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  batchId   String?
  batch     Batch?   @relation(fields: [batchId], references: [id])
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  certificate Certificate?

  @@map("enrollments")
}

model Batch {
  id        String   @id @default(cuid()) @map("_id")
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  label     String
  startDate DateTime
  endDate   DateTime
  seats     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  enrollments Enrollment[]

  @@map("batches")
}

model GalleryItem {
  id        String   @id @default(cuid()) @map("_id")
  imageUrl  String
  caption   String?
  category  String   @default("general") // general | facility | event | ceremony
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id])
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("gallery_items")
}

model Announcement {
  id        String   @id @default(cuid()) @map("_id")
  title     String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("announcements")
}

model Placement {
  id           String   @id @default(cuid()) @map("_id")
  studentName  String
  employerName String?
  courseId     String?
  course       Course?  @relation(fields: [courseId], references: [id])
  quote        String?
  batchYear    String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("placements")
}

model Faculty {
  id             String   @id @default(cuid()) @map("_id")
  name           String
  designation    String
  qualification  String?
  experience     String?
  specialization String?
  department     String?
  bio            String?
  photoUrl       String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@map("faculty")
}

model Certificate {
  id            String     @id @default(cuid()) @map("_id")
  certificateNo String     @unique
  enrollmentId  String     @unique
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id])
  studentName   String
  courseName    String
  issuedAt      DateTime   @default(now())

  @@map("certificates")
}

model AdminUser {
  id        String   @id @default(cuid()) @map("_id")
  email     String   @unique
  password  String
  name      String
  role      String   @default("EDITOR")
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model Setting {
  id        String   @id @default(cuid()) @map("_id")
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
